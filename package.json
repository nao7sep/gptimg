{
  "name": "gptimg",
  "version": "0.1.0",
  "description": "Batteries-included TypeScript toolkit for AI image generation, vision, and local chroma-key post-processing.",
  "license": "MIT",
  "author": {
    "name": "Yoshinao Inoguchi",
    "email": "nao7sep@gmail.com",
    "url": "https://github.com/nao7sep"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "gptimg": "./bin/gptimg.js"
  },
  "files": [
    "dist",
    "bin",
    "docs"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "culori": "^4.0.2",
    "defu": "^6.1.7",
    "dlv": "^1.1.3",
    "dset": "^3.1.4",
    "image-js": "^1.6.1",
    "openai": "^6.39.0",
    "p-limit": "^7.3.0",
    "sharp": "^0.34.5",
    "write-file-atomic": "^8.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "@types/dlv": "^1.1.5",
    "@types/node": "^25.9.1",
    "@types/write-file-atomic": "^4.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
