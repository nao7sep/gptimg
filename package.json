{
  "name": "gptimg",
  "version": "0.1.0",
  "private": true,
  "description": "Batteries-included TypeScript toolkit for AI image generation, vision, and local chroma-key post-processing.",
  "license": "MIT",
  "author": {
    "name": "Yoshinao Inoguchi",
    "email": "nao7sep@gmail.com",
    "url": "https://github.com/nao7sep"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nao7sep/gptimg.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@shockpkg/icon-encoder": "^3.2.3",
    "defu": "^6.1.7",
    "dset": "^3.1.4",
    "onnxruntime-node": "^1.26.0",
    "openai": "^6.44.0",
    "p-limit": "^7.3.0",
    "sharp": "^0.35.1",
    "write-file-atomic": "^8.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/write-file-atomic": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
